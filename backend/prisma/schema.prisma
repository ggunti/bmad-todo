generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Todo {
  id        String   @id @default(uuid())
  sessionId String
  text      String   @db.VarChar(1024)
  completed Boolean  @default(false)
  sortOrder Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sessionId])
}
