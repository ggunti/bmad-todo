# Database — use "localhost" for local dev outside Docker, "db" inside Docker
DATABASE_URL=postgresql://todo:todo@localhost:5432/todo_bmad

# Express server port
PORT=3001

# Environment flag
NODE_ENV=development

# Cookie signing secret — CHANGE THIS in production
COOKIE_SECRET=dev-secret-change-in-production

# Set Secure flag on cookies (false in dev, true in production behind HTTPS)
COOKIE_SECURE=false
